    "@types/express": "^5.0.6",
    "@types/mocha": "^10.0.10",
    "eslint": "^10.3.0",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@colyseus/bun-websockets": "^0.17.13",
    "@colyseus/monitor": "^0.17.8",
    "@colyseus/playground": "^0.17.12",
    "@colyseus/tools": "^0.17.19",
